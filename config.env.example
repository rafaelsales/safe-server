# safe-server configuration
# Copy this file to /etc/safe-server/config.env and adjust as needed.

# Grace window: how long public SSH stays open after each boot (minutes).
# The timer fires OnActiveSec after it starts, which means this many minutes
# after each boot AND this many minutes from initial install.
SAFE_SERVER_GRACE_MINUTES=60

# The private network interface SSH is restricted to after the grace window.
# Must match the interface name on your system (check: ip link show tailscale0).
SAFE_SERVER_PRIVATE_IFACE=tailscale0
